        }
      }
    },
    "Features": {
      "title": "Why Ithraa?",
      "items": {
        "tests": {
          "title": "Accredited assessments",
          "description": "A curated set of accurate, easy assessments to evaluate each child’s abilities."
        },
        "reports": {
          "title": "Clear reports",
          "description": "Rich results and actionable insights that give you a complete picture."
        },
        "dashboards": {
          "title": "Multiple dashboards",
          "description": "Role-based dashboards that make management and follow-up simple."
        }
      }
    },
    "HowItWorks": {
      "title": "How does Ithraa work?",
      "subtitle": "A simple journey that helps you discover and nurture a child’s strengths.",
      "steps": {
        "evaluate": {
          "title": "Run intelligence assessments",
          "description": "A set of structured tests to identify strengths and core skills."
        },
        "map": {
          "title": "Get a full intelligence map",
          "description": "Understand the child’s abilities clearly and build the right learning plan."
        },
        "recommend": {
          "title": "Smart activities & paths",
          "description": "Recommendations that match the child’s level and support steady growth."
        },
        "track": {
          "title": "Track progress and development",
          "description": "Follow improvement over time and adjust the path as needed."
        }
      }
    },
